<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="@color/background">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Illustration - Either Image or Emoji -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginBottom="20dp">

                <!-- Emoji Fallback -->
                <TextView
                    android:id="@+id/tv_illustration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚔️"
                    android:textSize="100sp"
                    android:layout_gravity="center"
                    android:contentDescription="Story illustration" />

                <!-- Wikipedia Image -->
                <ImageView
                    android:id="@+id/iv_story_image"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Historical figure image"
                    app:shapeAppearanceOverlay="@style/RoundedImageStyle" />
            </FrameLayout>

            <!-- Page number chip -->
            <TextView
                android:id="@+id/tv_page_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Page 1"
                android:textColor="@color/text_on_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/chip_bg"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tv_page_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_page_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:lineSpacingMultiplier="1.7"
                    android:gravity="center" />
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
